# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Configuration
# Use 'json' for local development (uses db.json), 'mongo' for production
DB_TYPE=json
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ineedstorage

# Cloud Storage (Cloudflare R2 / S3-compatible)
# Leave empty to use local uploads/ folder for development
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_PUBLIC_URL=https://pub-your-id.r2.dev

# Email Notifications (SMTP - Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="INeedStorage Alerts <your-email@gmail.com>"
